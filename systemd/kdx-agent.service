[Unit]
Description=KronosDX Appliance Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/kronosdx/agent
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 127.0.0.1 --port 7070
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
